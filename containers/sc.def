Bootstrap: localimage
From: base.sif
Stage: build

%post
    # Install BDWatchdog dependencies
    #wget https://raw.githubusercontent.com/UDC-GAC/BDWatchdog/master/MetricsFeeder/requirements.txt
    #pip install -r requirements.txt

    # Install Serverless Containers dependencies
    wget https://raw.githubusercontent.com/UDC-GAC/ServerlessContainers/master/requirements.txt
    wget https://raw.githubusercontent.com/UDC-GAC/ServerlessContainers/master/install.sh
    apt update
    bash install.sh

    wget https://github.com/mikefarah/yq/releases/download/v4.35.2/yq_linux_amd64.tar.gz
    tar xvf yq_linux_amd64.tar.gz
    mv yq_linux_amd64 /bin/yq
    apt install -y jq

