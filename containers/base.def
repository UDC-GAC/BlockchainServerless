Bootstrap: docker
From: ubuntu:{{ VERSION }}
Stage: build

%arguments
    VERSION=22.04


%post
    # Install fish shell
    apt update
    apt install -y software-properties-common
    apt-add-repository ppa:fish-shell/release-3
    apt update
    apt install -y fish
    fish -c "alias cxc 'set -gx tide_context_color_ssh bryellow && tide reload'"

    # Install tzdata, which usually asks for user input thus the fix
    DEBIAN_FRONTEND=noninteractive TZ=Europe/Madrird apt-get -y install tzdata

    # Basic cli utils
    apt install -y netcat atop htop git python3-pip python-is-python3 vim tree curl wget fio unzip net-tools screenfetch stress stress-ng iputils-ping iproute2

    # Install the newutils
    apt install -y bat exa

    # Install fisher
    fish -c "curl -sL https://raw.githubusercontent.com/jorgebucaran/fisher/main/functions/fisher.fish | source && fisher install jorgebucaran/fisher"
    fish -c "fisher install IlanCosman/tide@v6"

