Bootstrap: docker
From: ubuntu:{{ VERSION }}
Stage: build

%arguments
    VERSION=22.04


%post
    # Install fish shell
    apt update
    apt install -y software-properties-common
    apt-add-repository ppa:fish-shell/release-3
    apt update
    apt install -y fish
    fish -c "alias cxc 'set -gx tide_context_color_ssh bryellow && tide reload'"

    # Install tzdata, which usually asks for user input thus the fix
    DEBIAN_FRONTEND=noninteractive TZ=Europe/Madrid apt-get -y install tzdata

    # Basic cli utils
    apt install -y moreutils git python3-pip python-is-python3 vim curl wget unzip net-tools screenfetch screen

    # Install fisher
    fish -c "curl -sL https://raw.githubusercontent.com/jorgebucaran/fisher/main/functions/fisher.fish | source && fisher install jorgebucaran/fisher"
    fish -c "fisher install IlanCosman/tide@v6"

    # Needed for BDWatchdog MetricsFeeder
    apt install -y atop
    pip3 install requests pyyaml

