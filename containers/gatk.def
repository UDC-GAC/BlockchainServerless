Bootstrap: localimage
From: experiment.sif
Stage: build

%post
   	
	# Java 17
	apt update
	apt install -y openjdk-17-jdk
	apt install -y openjdk-17-jre
	
	# Samtools
	apt install -y samtools
	
	# Git LFS
	apt install -y git-lfs
	apt install -y python3-venv
